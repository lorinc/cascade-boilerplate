#!/bin/bash
# Pre-commit hook to prevent patchwork code
# Install: ln -s ../../.git-hooks/pre-commit .git/hooks/pre-commit

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Running pre-commit checks...${NC}"

# Check if this is an exploration branch
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [[ $BRANCH == explore/* ]]; then
  echo -e "${RED}❌ Error: Cannot commit on exploration branch${NC}"
  echo -e "${YELLOW}Exploration branches are for debugging only.${NC}"
  echo -e "${YELLOW}Create a clean implementation branch instead:${NC}"
  echo -e "  git checkout main"
  echo -e "  git checkout -b fix/your-fix-name"
  exit 1
fi

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${YELLOW}No files staged for commit${NC}"
  exit 0
fi

# Check for debug code in JavaScript/TypeScript files
echo "Checking for debug code..."
DEBUG_FOUND=0

for FILE in $STAGED_FILES; do
  if [[ $FILE =~ \.(js|jsx|ts|tsx)$ ]]; then
    # Check for console.log/debug/info/warn
    if git diff --cached $FILE | grep -E "^\+.*console\.(log|debug|info|warn)" > /dev/null; then
      echo -e "${RED}❌ Found console.log in: $FILE${NC}"
      DEBUG_FOUND=1
    fi
    
    # Check for debugger statements
    if git diff --cached $FILE | grep -E "^\+.*debugger" > /dev/null; then
      echo -e "${RED}❌ Found debugger statement in: $FILE${NC}"
      DEBUG_FOUND=1
    fi
    
    # Check for TODO/FIXME/HACK comments being added
    if git diff --cached $FILE | grep -E "^\+.*(TODO|FIXME|HACK|XXX):" > /dev/null; then
      echo -e "${YELLOW}⚠️  Found TODO/FIXME in: $FILE${NC}"
      echo -e "${YELLOW}   Consider creating an issue instead${NC}"
    fi
  fi
done

if [ $DEBUG_FOUND -eq 1 ]; then
  echo -e "${RED}❌ Error: Debug code found in staged files${NC}"
  echo -e "${YELLOW}Remove console.log and debugger statements before committing${NC}"
  exit 1
fi

# Check for large commented-out code blocks
echo "Checking for commented-out code..."
COMMENTED_CODE_FOUND=0

for FILE in $STAGED_FILES; do
  if [[ $FILE =~ \.(js|jsx|ts|tsx)$ ]]; then
    # Look for multiple consecutive commented lines (potential dead code)
    if git diff --cached $FILE | grep -E "^\+.*\/\/" | wc -l | awk '{if ($1 > 5) exit 0; else exit 1}'; then
      echo -e "${YELLOW}⚠️  Large commented block in: $FILE${NC}"
      echo -e "${YELLOW}   Consider removing instead of commenting${NC}"
    fi
  fi
done

# Check for merge conflict markers
echo "Checking for merge conflict markers..."
for FILE in $STAGED_FILES; do
  if grep -E "^(<<<<<<<|=======|>>>>>>>)" $FILE > /dev/null; then
    echo -e "${RED}❌ Found merge conflict markers in: $FILE${NC}"
    exit 1
  fi
done

# Run linter on staged files
echo "Running linter..."
if command -v npm &> /dev/null; then
  # Only lint staged files
  for FILE in $STAGED_FILES; do
    if [[ $FILE =~ \.(js|jsx|ts|tsx)$ ]]; then
      if [ -f "$FILE" ]; then
        npx eslint "$FILE" 2>/dev/null || {
          echo -e "${RED}❌ Linting failed for: $FILE${NC}"
          exit 1
        }
      fi
    fi
  done
fi

# Run tests (fast unit tests only)
echo "Running unit tests..."
if [ -f "package.json" ]; then
  npm run test:unit --silent 2>&1 | grep -E "(PASS|FAIL|Error)" || true
  
  if [ ${PIPESTATUS[0]} -ne 0 ]; then
    echo -e "${RED}❌ Unit tests failed${NC}"
    echo -e "${YELLOW}Fix tests before committing${NC}"
    exit 1
  fi
fi

echo -e "${GREEN}✅ Pre-commit checks passed${NC}"
exit 0
